rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // /workspaces/{workspaceId}/userProfiles/{uid}
    match /workspaces/{workspaceId}/userProfiles/{uid} {
      allow read, write: if isSelf(uid);
    }

    // /workspaces/{workspaceId}/users/{uid}/graph/linkStatus
    match /workspaces/{workspaceId}/users/{uid}/graph/{docId} {
      allow read, write: if isSelf(uid);
    }

    // /workspaces/{workspaceId}/users/{uid}/books/{bookId}
    match /workspaces/{workspaceId}/users/{uid}/books/{bookId} {
      allow read, write: if isSelf(uid);
    }

    // Block everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
